  "license": "MIT",
  "homepage": "https://github.com/marcelorodrigo/spring-crew-plugin",
  "devDependencies": {
    "@opencode-ai/plugin": "1.14.39",
    "@opencode-ai/sdk": "1.14.48",
    "tsup": "^8.0.0",
    "typescript": "6.0.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcelorodrigo/spring-crew-plugin.git"
  }
